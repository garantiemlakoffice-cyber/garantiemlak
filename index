<script>
    let isEditMode = false;
    function toggleEditMode() {
        isEditMode = !isEditMode;
        const btn = document.getElementById('editBtn');
        if(isEditMode) {
            document.body.classList.add('editable-active');
            btn.innerHTML = "💾 Düzenlemeyi Kapat (Kaydet)";
            btn.classList.replace('bg-yellow-500', 'bg-green-500');
            btn.classList.add('text-white');
            alert("Düzenleme Modu Açıldı! Sitedeki başlıkları, ilan yazılarını veya fiyatları doğrudan tıklayıp değiştirebilirsiniz.");
        } else {
            document.body.classList.remove('editable-active');
            btn.innerHTML = "⚙️ Düzenleme Modunu Aç";
            btn.classList.replace('bg-green-500', 'bg-yellow-500');
            btn.classList.remove('text-white');
            alert("Değişiklikler ekranınıza uygulandı!");
        }
    }
</script>

